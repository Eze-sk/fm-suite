{
  "name": "fm-suite",
  "devDependencies": {
    "eslint": "9.39.2",
    "husky": "9.1.7",
    "lint-staged": "16.3.3",
    "prettier": "3.7.4",
    "turbo": "2.7.4",
    "typescript": "5.9.2",
    "typescript-eslint": "8.53.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
